{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HandoffStartRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "source",
    "include_gmail",
    "open_loops",
    "response_channel",
    "timezone"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "request_id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "enum": [
        "ios_app",
        "macos_app",
        "photon_message",
        "debug"
      ]
    },
    "include_gmail": {
      "type": "boolean"
    },
    "gmail_account_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "open_loops": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "text"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "desired_time": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "tomorrow_morning",
              "tomorrow",
              "later",
              null
            ]
          }
        }
      }
    },
    "response_channel": {
      "type": "string",
      "enum": [
        "app",
        "imessage"
      ]
    },
    "timezone": {
      "type": "string",
      "minLength": 1
    },
    "locale": {
      "type": "string",
      "default": "zh-CN"
    }
  }
}
