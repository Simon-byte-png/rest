{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FatigueCheckIn",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "session_id",
    "source",
    "description",
    "input_mode",
    "available_minutes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "request_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "enum": [
        "manual_ios",
        "manual_macos",
        "photon_message",
        "notification",
        "debug"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "input_mode": {
      "type": "string",
      "enum": [
        "text",
        "voice",
        "quick_tag"
      ]
    },
    "available_minutes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "willing_to_move": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "current_place": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 80
    },
    "follow_up_answer": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 100
    }
  }
}
