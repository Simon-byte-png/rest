{
  "name": "@hush/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.19 <21",
    "pnpm": ">=9 <10"
  },
  "scripts": {
    "dev": "tsx watch src/bootstrap.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/bootstrap.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:contracts": "vitest run tests/contracts",
    "test:providers": "vitest run tests/provider-contracts",
    "test:integration": "vitest run tests/integration",
    "test:vertical": "vitest run tests/vertical-slice",
    "smoke": "vitest run tests/integration/server.test.ts",
    "check": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.113.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "20.19.9",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
